rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Allowance data — keyed by the child's UID
    match /allowance/{docId} {
      // Child can read their own document (read-only — writes go via parent)
      allow read: if request.auth != null && request.auth.uid == docId;

      // Parents can read AND write the child's document
      // Replace the UID strings below with your actual parent UIDs
      allow read, write: if request.auth != null
        && request.auth.uid in ["qLzqT8HLNCN9FSVWZESZthP1DaJ3", "KveGzOt05sWVm8DvO1sBpyxg3z52"];
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
